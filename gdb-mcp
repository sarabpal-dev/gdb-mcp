    # ── Data Inspection ────────────────────────────────────────────

    @app.tool()
    def gdb_evaluate_expression(expression: str) -> str:
        """Evaluate any GDB expression and return the result.
        Supports C expressions, casts, dereferences, GDB convenience vars, etc.
        Args: expression: e.g. 'sizeof(struct task_struct)', '*(int*)0x7fff5000', '$rax+8'."""
        return _run_gdb_command_with_echo(f"print {expression}", source="MCP", echo=True)

    @app.tool()
    def gdb_get_variables() -> str:
        """Get all local variables in the current frame.
        Returns: info locals output."""
        return _run_gdb_command_with_echo("info locals", source="MCP", echo=True)

    @app.tool()
    def gdb_get_registers(register_set: str = "") -> str:
        """Get CPU register values.
        Args: register_set: Empty for general regs, 'all' for all, or specific like 'rax rbx'."""
        if register_set == "all":
            return _run_gdb_command_with_echo("info all-registers", source="MCP", echo=True)
        elif register_set:
            return _run_gdb_command_with_echo(f"info registers {register_set}", source="MCP", echo=True)
        return _run_gdb_command_with_echo("info registers", source="MCP", echo=True)

    @app.tool()
    def gdb_read_memory(address: str, count: int = 16, format: str = "x", size: str = "b") -> str:
        """Read memory using GDB's x command.
        Args:
            address: Start address (e.g. '0x7fff5000', '$rsp', '&variable')
            count: Number of units to display
            format: x(hex) d(decimal) u(unsigned) o(octal) t(binary) a(addr) c(char) s(string) i(instruction)
            size: b(byte) h(halfword/2B) w(word/4B) g(giant/8B)."""
        return _run_gdb_command_with_echo(f"x/{count}{format}{size} {address}", source="MCP", echo=True)

    @app.tool()
    def gdb_disassemble(location: str = "", count: int = 0) -> str:
        """Disassemble instructions at a location.
        Args:
            location: Function name, address, or empty for current PC
            count: If >0, disassemble this many instructions from location."""
        if count > 0 and location:
            return _run_gdb_command_with_echo(f"x/{count}i {location}", source="MCP", echo=True)
        elif location:
            return _run_gdb_command_with_echo(f"disassemble {location}", source="MCP", echo=True)
        return _run_gdb_command_with_echo("disassemble", source="MCP", echo=True)

    @app.tool()
    def gdb_write_memory(address: str, values: list[str]) -> str:
        """Write values to memory. Each value is set as a byte.
        Args:
            address: Start address (e.g. '0x7fff5000')
            values: List of byte values as hex strings (e.g. ['0x90', '0xcc'])."""
        results = []
        for i, val in enumerate(values):
            r = _run_gdb_command_with_echo(
                f"set *(unsigned char*)({address} + {i}) = {val}",
                source="MCP", echo=True)
            results.append(r)
        verify = _run_gdb_command_with_echo(
            f"x/{len(values)}xb {address}", source="MCP", echo=True)
        return f"Wrote {len(values)} bytes at {address}\n{verify}"

    # Keywords that open a block requiring a matching 'end'
    _BLOCK_OPENERS = frozenset([
        'if', 'while', 'define', 'document', 'commands', 'python', 'loop_break',
    ])

    def _is_block_opener(line):
        """Check if a GDB command line opens a block that needs 'end'."""
        stripped = line.strip().split()[0] if line.strip() else ''
        return stripped in _BLOCK_OPENERS

    @app.tool()
    def gdb_run_script(commands: list[str]) -> str:
        """Execute a multi-line GDB script with FULL block-awareness.

        Automatically detects multi-line GDB constructs (while...end,
        if...else...end, define...end, commands...end, python...end, etc.)
        and sends them as atomic blocks so they execute correctly.

        Single-line commands are sent individually. Prefix any command
        with '-' to ignore errors on that command and continue.

        Examples:
            Simple sequential:
                ["break main", "run", "info registers", "bt"]

            Breakpoint with commands:
                ["break main",
                 "commands 1", "silent", "print $rax", "continue", "end",
                 "run"]

            While loop:
                ["set $i = 0",
                 "while $i < 10", "stepi", "set $i = $i + 1", "end",
                 "info registers"]

            Define custom command:
                ["define dump_regs", "info registers", "x/16xg $rsp", "end",
                 "break main", "run", "dump_regs"]

            Nested if/while:
                ["define smart_step",
                 "set $n = 0",
                 "while $n < $arg0",
                 "stepi",
                 "if $pc == $arg1", "print $rax", "loop_break", "end",
                 "set $n = $n + 1",
                 "end",
                 "end"]

            Ignore errors with '-' prefix:
                ["-delete", "break *0x400520", "run"]

        Args:
            commands: List of GDB command lines to execute in order.
        Returns:
            Combined output from all commands/blocks with numbering.
        """
        outputs = []
        i = 0
        block_num = 0

        while i < len(commands):
            cmd = commands[i]
            ignore_err = cmd.startswith('-')
            actual_line = cmd[1:].strip() if ignore_err else cmd.strip()

            # Check if this line opens a block
            if _is_block_opener(actual_line):
                # Accumulate lines until we close all nested blocks
                block_lines = [actual_line]
                depth = 1
                i += 1
                while i < len(commands) and depth > 0:
                    bline = commands[i].strip()
                    # Strip '-' prefix inside blocks (only meaningful at top level)
                    if bline.startswith('-'):
                        bline = bline[1:].strip()
                    block_lines.append(bline)
                    if _is_block_opener(bline):
                        depth += 1
                    elif bline == 'end':
                        depth -= 1
                    i += 1

                block_num += 1
                block_script = '\n'.join(block_lines)

                try:
                    out = _run_gdb_command_with_echo(block_script, source="MCP", echo=True)
                    outputs.append(f"[block {block_num}] {block_lines[0]} ... end\n{out}")
                except Exception as e:
                    err_msg = f"[block {block_num}] {block_lines[0]} ... end\nERROR: {e}"
                    outputs.append(err_msg)
                    if not ignore_err:
                        outputs.append(f"(Script stopped at block {block_num})")
                        break
            else:
                # Single command — send individually
                block_num += 1
                try:
                    out = _run_gdb_command_with_echo(actual_line, source="MCP", echo=True)
                    outputs.append(f"[{block_num}] {actual_line}\n{out}")
                except Exception as e:
                    err_msg = f"[{block_num}] {actual_line}\nERROR: {e}"
                    outputs.append(err_msg)
                    if not ignore_err:
                        outputs.append(f"(Script stopped at command {block_num})")
                        break
                i += 1

        return "\n".join(outputs)

    @app.tool()
    def gdb_execute_script(script: str) -> str:
        """Execute a raw multi-line GDB script as a single block.

        Takes the ENTIRE script as one string (with newlines) and sends it
        directly to gdb.execute(). This is the most powerful scripting tool —
        it handles arbitrarily complex scripts exactly as if you typed them
        into GDB's interactive prompt.

        Use this for complex scripts where you want full control over the
        exact text sent to GDB. For simpler use cases, prefer gdb_run_script.

        Examples:
            "break main\\nrun\\ninfo registers"

            "define trace_calls\\n  silent\\n  bt 3\\n  continue\\nend"

            "set $base = 0x7fff0000\\nset $i = 0\\nwhile $i < 256\\n  x/1xb $base + $i\\n  set $i = $i + 1\\nend"

            "python\\nimport struct\\nmem = gdb.selected_inferior().read_memory(0x400000, 64)\\nfor i in range(0, 64, 8):\\n    val = struct.unpack('<Q', mem[i:i+8])[0]\\n    print(f'0x{0x400000+i:x}: 0x{val:016x}')\\nend"

        Args:
            script: Complete GDB script text with embedded newlines.
        Returns:
            Output from executing the script.
        """
        return _run_gdb_command_with_echo(script, source="MCP", echo=True)

    @app.tool()
    def gdb_set_variable(variable: str, value: str) -> str:
        """Set a GDB variable or program variable.
        Args:
            variable: Variable name (e.g. '$rax', 'myvar', '$convenience_var')
            value: Value to set (e.g. '42', '0x1000', '"hello"')."""
        return _run_gdb_command_with_echo(f"set {variable} = {value}", source="MCP", echo=True)

    @app.tool()
    def gdb_define_function(name: str, body: list[str]) -> str:
        """Define a custom GDB command (like 'define' in GDB).
        Args:
            name: Command name to define
            body: List of GDB commands forming the body."""
        script = f"define {name}\n"
        for line in body:
            script += f"{line}\n"
        script += "end"
        return _run_gdb_command_with_echo(script, source="MCP", echo=True)

    @app.tool()
    def gdb_source_file(filepath: str) -> str:
        """Source/load a GDB script file.
        Args: filepath: Path to a GDB script file (.gdb, .py, etc.)."""
        return _run_gdb_command_with_echo(f"source {filepath}", source="MCP", echo=True)

    @app.tool()
    def gdb_set_option(option: str) -> str:
        """Set any GDB option (pass the full 'set ...' argument).
        Examples: 'pagination off', 'print pretty on', 'disassembly-flavor intel'.
        Args: option: The option string after 'set'."""
        return _run_gdb_command_with_echo(f"set {option}", source="MCP", echo=True)

    @app.tool()
    def gdb_show_option(option: str) -> str:
        """Show any GDB option value.
        Args: option: The option to query (e.g. 'disassembly-flavor', 'pagination')."""
        return _run_gdb_command_with_echo(f"show {option}", source="MCP", echo=True)

    @app.tool()
    def gdb_watchpoint(expression: str, watch_type: str = "write") -> str:
        """Set a watchpoint on an expression.
        Args:
            expression: Expression to watch (e.g. '*0x7fff5000', 'myvar')
            watch_type: 'write' (stop on write), 'read' (stop on read), 'access' (both)."""
        if watch_type == "read":
            cmd = f"rwatch {expression}"
        elif watch_type == "access":
            cmd = f"awatch {expression}"
        else:
            cmd = f"watch {expression}"
        return _run_gdb_command_with_echo(cmd, source="MCP", echo=True)

    @app.tool()
    def gdb_catchpoint(event: str) -> str:
        """Set a catchpoint for system events.
        Args: event: Event to catch - 'syscall', 'throw', 'catch', 'fork', 'exec',
              'signal SIGNAME', 'syscall NAME/NUMBER', etc."""
        return _run_gdb_command_with_echo(f"catch {event}", source="MCP", echo=True)

    def run_sse(host, port):
        import asyncio
        # Suppress uvicorn access logs (it reconfigures loggers on startup)
        for _name in ("uvicorn", "uvicorn.access", "uvicorn.error"):
            logging.getLogger(_name).setLevel(logging.WARNING)
        asyncio.run(app.run_async(
            transport="sse", host=host, port=port,
            log_level="warning",
        ))

    return app, run_sse


class McpServerCommand(gdb.Command):
    """Start a FastMCP SSE server inside GDB with screen mirroring.
Usage:
  mcp-server <host> <port>
Example:
  mcp-server 127.0.0.1 3333
    """

    def __init__(self):
        super(McpServerCommand, self).__init__("mcp-server", gdb.COMMAND_USER)

    def invoke(self, arg, from_tty):
        global _mcp_thread, _mcp_running, _command_logger, _prompt_capture
        argv = gdb.string_to_argv(arg)
        if len(argv) != 2:
            raise gdb.GdbError("usage: mcp-server <host> <port>")
        host, port_str = argv[0], argv[1]
        try:
            port = int(port_str)
        except ValueError:
            raise gdb.GdbError("port must be an integer")

        if _mcp_running:
            gdb.write("[mcp] Server already running\n")
            return
        
        # Initialize command logger if not already done
        if _command_logger is None:
            _command_logger = CommandLogger(max_history=1000)
            gdb.write("[mcp] Command logger initialized (history size: 1000)\n")
        
        # Initialize prompt-based output capture
        if _prompt_capture is None:
            _prompt_capture = PromptOutputCapture(_command_logger)
            try:
                _prompt_capture.start()
                gdb.write("[mcp] Prompt-hook output capture installed — user commands + outputs will be captured\n")
            except Exception as e:
                gdb.write(f"[mcp] Warning: Could not install prompt capture: {e}\n", gdb.STDERR)
                gdb.write("[mcp] User command outputs will not be captured\n")

        app, runner = _build_fastmcp_app()
        if app is None or runner is None:
            raise gdb.GdbError("Failed to initialize FastMCP server")

        def _serve():
            global _mcp_running
            _mcp_running = True
            try:
                gdb.write(f"[mcp] Starting SSE server on {host}:{port}...\n")
                gdb.write("[mcp] Screen mirroring enabled - MCP commands will be visible in console\n")
                runner(host, port)
            except Exception:
                traceback.print_exc()
            finally:
                _mcp_running = False
                gdb.write("[mcp] Server stopped\n")

        _mcp_thread = threading.Thread(target=_serve, name="gdb-mcp-sse", daemon=True)
        _mcp_thread.start()
        gdb.write("[mcp] Server launched in background.\n")


class McpStatusCommand(gdb.Command):
    """Show MCP server and screen mirroring status.
Usage:
  mcp-status
    """

    def __init__(self):
        super(McpStatusCommand, self).__init__("mcp-status", gdb.COMMAND_USER)

    def invoke(self, arg, from_tty):
        global _mcp_running, _command_logger, _prompt_capture
        
        gdb.write("\n=== GDB MCP Server Status ===\n")
        gdb.write(f"Server Status: {'Running' if _mcp_running else 'Stopped'}\n")
        gdb.write(f"Screen Mirroring: {'Enabled' if _command_logger else 'Disabled'}\n")
        
        if _prompt_capture:
            gdb.write(f"User Command Capture: {'Installed (prompt_hook)' if _prompt_capture.installed else 'Not installed'}\n")
            gdb.write(f"Log File: {_prompt_capture.log_file or 'None'}\n")
            gdb.write(f"Last Command #: {_prompt_capture.last_cmd_num}\n")
        else:
            gdb.write("User Command Capture: Disabled\n")
        
        if _command_logger:
            stats = _command_logger.get_stats()
            gdb.write(f"\n=== Command History Statistics ===\n")
            gdb.write(f"Total Commands: {stats['total_commands']}\n")
            gdb.write(f"User Commands: {stats['user_commands']}\n")
            gdb.write(f"MCP Commands: {stats['mcp_commands']}\n")
            gdb.write(f"System Commands: {stats['system_commands']}\n")
            gdb.write(f"History Buffer Size: {stats['max_history']}\n")
        
        gdb.write("\n")


