    @app.tool()
    def gdb_stepi(count: int = 1) -> str:
        """Step one machine instruction, entering calls.
        Args: count: Number of instructions to step."""
        return _run_gdb_command_with_echo(f"stepi {count}", source="MCP", echo=True)

    @app.tool()
    def gdb_nexti(count: int = 1) -> str:
        """Step one machine instruction, skipping over calls.
