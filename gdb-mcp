class CommandLogger:
    """Thread-safe command and output logger for screen mirroring"""
    
    def __init__(self, max_history=1000):
        self.history = deque(maxlen=max_history)
        self.max_history = max_history
        self.lock = threading.Lock()
    
    def log_command(self, source, command, output, timestamp=None):
        """
        Log a command with its output and source attribution.
        
        Args:
            source: Command source ("USER", "MCP", or "SYSTEM")
            command: The command string that was executed
            output: The output from the command
            timestamp: Optional timestamp (defaults to current time)
        """
        if timestamp is None:
            timestamp = time.time()
        
        entry = {
            "timestamp": timestamp,
            "source": source,
            "command": command,
            "output": output,
            "output_size": len(output) if output else 0
        }
        
        with self.lock:
            self.history.append(entry)
    
    def get_history(self, limit=50, source_filter=None):
        """
        Retrieve command history with optional filtering.
        
        Args:
            limit: Maximum number of entries to return
            source_filter: Optional filter by source ("USER", "MCP", "SYSTEM", or None for all)
        
        Returns:
            List of history entries (most recent first)
        """
        with self.lock:
            # Convert deque to list and reverse for most recent first
            history_list = list(self.history)
            history_list.reverse()
            
            # Apply source filter if specified
            if source_filter and source_filter.upper() != "ALL":
                history_list = [
                    entry for entry in history_list 
                    if entry["source"].upper() == source_filter.upper()
                ]
            
            # Apply limit
            return history_list[:limit]
    
    def get_recent_output(self, count=1):
        """
        Get output from the last N commands.
        
        Args:
            count: Number of recent command outputs to retrieve
        
        Returns:
            List of output strings (most recent first)
        """
        with self.lock:
            history_list = list(self.history)
            history_list.reverse()
            return [entry["output"] for entry in history_list[:count]]
    
    def get_stats(self):
        """Get statistics about the command history"""
        with self.lock:
            total = len(self.history)
            if total == 0:
                return {
                    "total_commands": 0,
                    "user_commands": 0,
                    "mcp_commands": 0,
                    "system_commands": 0
                }
            
            user_count = sum(1 for e in self.history if e["source"] == "USER")
            mcp_count = sum(1 for e in self.history if e["source"] == "MCP")
            system_count = sum(1 for e in self.history if e["source"] == "SYSTEM")
            
            return {
                "total_commands": total,
                "user_commands": user_count,
                "mcp_commands": mcp_count,
                "system_commands": system_count,
                "max_history": self.max_history
            }


class PromptOutputCapture:
    """Capture user command outputs using gdb.prompt_hook.
    
    gdb.prompt_hook fires synchronously in the GDB main thread right before
    GDB displays the next prompt. At that point:
      - The previous command has already finished executing
      - All output has already been written to the log file
      - We can read the log delta (last_position → current_position) to get output
      - We can check `show commands` to identify what command produced it
    
    This solves the fundamental timing issue of the old polling approach where
    we detected commands AFTER their output was already written, making
    position-based tracking impossible.
    """
    
    def __init__(self, command_logger):
        self.command_logger = command_logger
        self.log_file = None
        self.log_enabled = False
        self.last_log_position = 0
        self.last_cmd_num = 0
        self.installed = False
        # Commands to skip (internal/MCP commands that we log separately)
        self.skip_commands = frozenset([
            'show commands', 'show logging', 'mcp-server', 'mcp-status',
            'set logging file', 'set logging overwrite',
            'set logging redirect', 'set logging enabled',
        ])
    
    def start(self):
        """Enable GDB logging and install the prompt hook."""
        if self.installed:
            return
        
        # Enable GDB logging to capture outputs
        try:
            pid = os.getpid()
            self.log_file = f"/tmp/gdb-output-{pid}.log"
            gdb.execute(f"set logging file {self.log_file}")
            gdb.execute("set logging overwrite off")
            gdb.execute("set logging redirect off")
            gdb.execute("set logging enabled on")
            self.log_enabled = True
        except Exception as e:
            gdb.write(f"[mcp] Warning: Could not enable output logging: {e}\n", gdb.STDERR)
            return
        
        # Initialize log position to current end-of-file
        self.last_log_position = self._get_log_position()
        
        # Initialize last command number from history
        self.last_cmd_num = self._get_last_cmd_num()
        
        # Install prompt hook
        # gdb.prompt_hook is called synchronously before each prompt display.
        # We save any previous hook and chain to it.
        self._prev_prompt_hook = gdb.prompt_hook
        gdb.prompt_hook = self._prompt_hook
        self.installed = True
    
    def stop(self):
        """Uninstall the prompt hook."""
        if not self.installed:
            return
        gdb.prompt_hook = self._prev_prompt_hook
        self.installed = False
    
    def _prompt_hook(self, current_prompt):
        """Called synchronously by GDB before displaying each prompt.
        
        At this point the previous command has finished and its output
        is fully written to the log file. We:
          1. Read the log delta since the last prompt
          2. Check if a new user command appeared in history
          3. If so, log the command with its captured output
          4. Update the log position for the next cycle
        """
        try:
            self._capture_cycle()
        except Exception:
            # Never let exceptions escape the prompt hook — that would break GDB
            pass
        
        # Chain to previous prompt hook if any
        if self._prev_prompt_hook:
            return self._prev_prompt_hook(current_prompt)
        return None
    
    def _capture_cycle(self):
        """One capture cycle: detect new command + read its output from log."""
        if not self.log_enabled:
            return
        
        # 1. Read log output since last prompt
        current_pos = self._get_log_position()
        output = ""
        if current_pos > self.last_log_position:
            output = self._read_log_range(self.last_log_position, current_pos)
            output = self._clean_output(output)
        
        # 2. Check for new user command(s)
        current_cmd_num, commands = self._get_new_commands()
        
        if commands:
            # We have new user commands since last prompt.
            # For a single command (the common case), the entire log delta
            # is that command's output.
            # For multiple rapid commands (rare in interactive use), we
            # attribute the combined output to the last command and log
            # earlier commands with empty output.
            
            if len(commands) == 1:
                cmd_num, cmd_text = commands[0]
                self.command_logger.log_command(
                    source="USER",
                    command=cmd_text,
                    output=output
                )
            else:
                # Multiple commands detected between prompts.
                # Log earlier ones with empty output, last one gets the output.
                for cmd_num, cmd_text in commands[:-1]:
                    self.command_logger.log_command(
                        source="USER",
                        command=cmd_text,
                        output=""
                    )
                last_num, last_text = commands[-1]
                self.command_logger.log_command(
                    source="USER",
                    command=last_text,
                    output=output
                )
        
        # 3. Update position for next cycle
        self.last_log_position = current_pos
        self.last_cmd_num = current_cmd_num if current_cmd_num > self.last_cmd_num else self.last_cmd_num
    
    def _get_last_cmd_num(self):
        """Get the highest command number from GDB history."""
        try:
            history = gdb.execute("show commands", to_string=True)
            lines = history.strip().split('\n')
            max_num = 0
            for line in lines:
                match = re.match(r'\s+(\d+)\s+', line)
                if match:
                    num = int(match.group(1))
                    if num > max_num:
                        max_num = num
            return max_num
        except Exception:
            return 0
    
    def _get_new_commands(self):
        """Get new commands since last_cmd_num.
        
        Returns:
            (current_max_num, [(cmd_num, cmd_text), ...])
            where the list only contains user commands (not MCP/internal).
        """
        try:
            history = gdb.execute("show commands", to_string=True)
        except Exception:
            return self.last_cmd_num, []
        
        lines = history.strip().split('\n')
        max_num = self.last_cmd_num
        new_commands = []
        
        for line in lines:
            match = re.match(r'\s+(\d+)\s+(.+)$', line)
            if not match:
                continue
            
            cmd_num = int(match.group(1))
            cmd_text = match.group(2).strip()
            
            if cmd_num > max_num:
                max_num = cmd_num
            
            # Only process commands newer than what we've seen
            if cmd_num <= self.last_cmd_num:
                continue
            
            # Skip internal/MCP commands
            if (cmd_text.startswith('[MCP]') or
                cmd_text.startswith('[SYSTEM]') or
                cmd_text in self.skip_commands or
                cmd_text.startswith('set logging') or
                cmd_text.startswith('show commands')):
                continue
            
            new_commands.append((cmd_num, cmd_text))
        
        return max_num, new_commands
    
    def _get_log_position(self):
        """Get current end-of-file position in log file."""
        if not self.log_enabled or not self.log_file:
            return 0
        try:
            if os.path.exists(self.log_file):
                with open(self.log_file, 'r') as f:
                    f.seek(0, 2)  # Seek to end
                    return f.tell()
        except Exception:
            pass
        return 0
    
    def _read_log_range(self, start_pos, end_pos):
        """Read log file from start_pos to end_pos with size limits."""
        if not self.log_enabled or not self.log_file:
            return ""
        try:
            if not os.path.exists(self.log_file):
                return ""
            with open(self.log_file, 'r') as f:
                f.seek(start_pos)
                bytes_to_read = end_pos - start_pos
                if bytes_to_read <= 0:
                    return ""
                # Limit to 100KB per command
                max_read = 100 * 1024
                if bytes_to_read > max_read:
                    output = f.read(max_read)
                    truncated_bytes = bytes_to_read - max_read
                    return output + f"\n\n... (output truncated, {truncated_bytes:,} bytes omitted)"
                else:
                    return f.read(bytes_to_read)
        except Exception as e:
            return f"(error reading output: {e})"
    
    def _clean_output(self, raw_output):
        """Clean and validate captured output."""
        if not raw_output:
            return ""
        
        lines = raw_output.split('\n')
        cleaned_lines = []
        
        for line in lines:
            # Skip MCP/SYSTEM prefixes echoed to log
            if line.startswith('[MCP]') or line.startswith('[SYSTEM]'):
                continue
            cleaned_lines.append(line)
        
        # Remove leading empty lines
        while cleaned_lines and not cleaned_lines[0].strip():
            cleaned_lines.pop(0)
        
        # Remove trailing empty lines
        while cleaned_lines and not cleaned_lines[-1].strip():
            cleaned_lines.pop()
        
        return '\n'.join(cleaned_lines)


def _run_gdb_command(cmd: str) -> str:
    """
    Execute a GDB command (original implementation without echo).
    Used internally for system commands that don't need visibility.
    """
    result = {"out": "", "err": None, "done": False}
    cond = threading.Condition()

    def _do_exec():
        try:
            out = gdb.execute(cmd, to_string=True)
            with cond:
                result["out"] = out
                result["done"] = True
                cond.notify_all()
        except Exception as ex:
            with cond:
                result["err"] = f"{type(ex).__name__}: {ex}"
                result["done"] = True
                cond.notify_all()

    gdb.post_event(_do_exec)
    with cond:
        while not result["done"]:
            cond.wait(timeout=0.05)
    if result["err"]:
        return f"ERROR: {result['err']}"
    return result["out"]


def _run_gdb_command_with_echo(cmd: str, source="MCP", echo=True) -> str:
    """
    Execute a GDB command with console echo and logging for screen mirroring.
    
    Args:
        cmd: The GDB command to execute
        source: Command source attribution ("MCP", "USER", "SYSTEM")
        echo: Whether to echo the command and output to console
    
    Returns:
        Command output string or error message
    """
    result = {"out": "", "err": None, "done": False}
    cond = threading.Condition()
    
    # Echo command to console if requested
    if echo and source != "SYSTEM":
        gdb.write(f"\n[{source}] {cmd}\n", gdb.STDLOG)
    
    def _do_exec():
        try:
            # Execute command and capture output
            out = gdb.execute(cmd, to_string=True)
            
            # Echo output to console if requested
            if echo and out:
                gdb.write(out, gdb.STDOUT)
            
            with cond:
                result["out"] = out if out else ""
                result["done"] = True
                cond.notify_all()
            
            # Log to history
            if _command_logger:
                _command_logger.log_command(source, cmd, out if out else "")
                
        except Exception as ex:
            err_msg = f"{type(ex).__name__}: {ex}"
            
            # Echo error to console if requested
            if echo:
                gdb.write(f"ERROR: {err_msg}\n", gdb.STDERR)
            
            with cond:
                result["err"] = err_msg
                result["done"] = True
                cond.notify_all()
            
            # Log error to history
            if _command_logger:
                _command_logger.log_command(source, cmd, f"ERROR: {err_msg}")
    
    gdb.post_event(_do_exec)
    
    with cond:
        while not result["done"]:
            cond.wait(timeout=0.05)
    
    if result["err"]:
        return f"ERROR: {result['err']}"
    return result["out"]


def _build_fastmcp_app():
    try:
        from fastmcp import FastMCP
    except Exception as e:
        gdb.write(f"[mcp] Failed to import fastmcp: {e}\n")
        return None, None

    app = FastMCP("gdb-mcp")

    @app.tool()
    def gdb_command(command: str) -> str:
        """
        Execute a GDB command with console echo and logging.
        The command and its output will be visible in the GDB console with [MCP] prefix.
        
        Args:
            command: The GDB command to execute (e.g., "info registers", "backtrace")
        
        Returns:
            Command output as string
        """
        return _run_gdb_command_with_echo(command, source="MCP", echo=True)
    
    @app.tool()
    def get_command_history(limit: int = 50, source: str = "ALL") -> str:
        """
        Retrieve command history with optional source filtering.
        Useful for understanding what commands have been executed and their outputs.
        
        Args:
            limit: Maximum number of history entries to return (default: 50)
            source: Filter by command source - "USER", "MCP", "SYSTEM", or "ALL" (default: "ALL")
        
        Returns:
            JSON string containing command history with timestamps, sources, commands, and outputs
        """
        if not _command_logger:
            return json.dumps({"error": "Command logger not initialized"})
        
        history = _command_logger.get_history(limit, source)
        return json.dumps(history, indent=2)
    
    @app.tool()
    def get_recent_output(count: int = 1) -> str:
        """
        Get output from the last N commands.
        Useful for retrieving recent command results without full history.
        
        Args:
            count: Number of recent command outputs to retrieve (default: 1)
        
        Returns:
            Concatenated output from the last N commands, separated by "---"
        """
        if not _command_logger:
            return "ERROR: Command logger not initialized"
        
        outputs = _command_logger.get_recent_output(count)
        return "\n---\n".join(outputs)
    
    @app.tool()
    def get_console_state() -> str:
        """
        Get a snapshot of current GDB debugging state.
        Includes backtrace, registers, and thread information.
        
        Returns:
            JSON string containing current GDB state
        """
        state = {}
        
        # Get backtrace
        try:
            state['backtrace'] = _run_gdb_command_with_echo("bt", source="SYSTEM", echo=False)
        except Exception as e:
            state['backtrace'] = f"ERROR: {e}"
        
        # Get registers
        try:
            state['registers'] = _run_gdb_command_with_echo("info registers", source="SYSTEM", echo=False)
        except Exception as e:
            state['registers'] = f"ERROR: {e}"
        
        # Get threads
        try:
            state['threads'] = _run_gdb_command_with_echo("info threads", source="SYSTEM", echo=False)
        except Exception as e:
            state['threads'] = f"ERROR: {e}"
        
        return json.dumps(state, indent=2)
    
    @app.tool()
    def get_logger_stats() -> str:
        """
        Get statistics about command history and logger status.
        
        Returns:
            JSON string containing logger statistics
        """
        if not _command_logger:
            return json.dumps({"error": "Command logger not initialized"})
        
        stats = _command_logger.get_stats()
        return json.dumps(stats, indent=2)

    @app.tool()
    def set_breakpoint_commands(breakpoint_number: int, commands: list[str], silent: bool = False) -> str:
        """
        Set up a command script for a breakpoint, just like GDB's interactive:
          (gdb) commands <breakpoint_number>
          Type commands for breakpoint(s) N, one per line.
          End with a line saying just "end".
          > <cmd1>
          > <cmd2>
          > end

        The commands will execute automatically every time the breakpoint is hit.

        Common use cases:
          - Print variables and continue: ["print x", "print y", "continue"]
          - Log silently:  silent=True, ["printf \"x=%d\\n\", x", "continue"]
          - Conditional action: ["if x > 100", "print x", "end", "continue"]

        Args:
            breakpoint_number: The breakpoint number (from 'info breakpoints')
            commands: List of GDB commands to execute when breakpoint is hit
            silent: If True, prepends 'silent' so the breakpoint hit is not announced

        Returns:
            Confirmation message or error
        """
        if not commands:
            return "ERROR: commands list cannot be empty"

        # Build the multi-line commands block for gdb.execute
        # GDB accepts this as a single string with embedded newlines
        cmd_lines = []
        if silent:
            cmd_lines.append("silent")
        cmd_lines.extend(commands)

        # Construct the full commands block:
        #   commands <N>
        #   <line1>
        #   <line2>
        #   end
        script = f"commands {breakpoint_number}\n"
        for line in cmd_lines:
            script += f"{line}\n"
        script += "end"

        result = _run_gdb_command_with_echo(script, source="MCP", echo=True)

        # Verify by checking the breakpoint info
        verify = _run_gdb_command_with_echo(
            f"info breakpoints {breakpoint_number}",
            source="SYSTEM", echo=False
        )

        return (
            f"Commands set for breakpoint {breakpoint_number}:\n"
            f"  Silent: {silent}\n"
            f"  Commands ({len(commands)}):\n"
            + "\n".join(f"    > {c}" for c in commands)
            + f"\n\nBreakpoint info:\n{verify}"
        )

    @app.tool()
    def get_breakpoint_commands(breakpoint_number: int = 0) -> str:
        """
        Show the commands attached to a breakpoint.
        If breakpoint_number is 0, shows commands for all breakpoints.

        This is equivalent to:
          (gdb) info breakpoints <N>
        and inspecting the command list attached.

        Args:
            breakpoint_number: Breakpoint number (0 = all breakpoints)

        Returns:
            Breakpoint info including any attached command scripts
        """
        if breakpoint_number > 0:
            cmd = f"info breakpoints {breakpoint_number}"
        else:
            cmd = "info breakpoints"

        return _run_gdb_command_with_echo(cmd, source="MCP", echo=True)

    @app.tool()
    def clear_breakpoint_commands(breakpoint_number: int) -> str:
        """
        Remove all commands attached to a breakpoint.
        Sets an empty command list, so the breakpoint just stops normally.

        Equivalent to:
          (gdb) commands <N>
          > end

        Args:
            breakpoint_number: The breakpoint number to clear commands from

        Returns:
            Confirmation message
        """
        script = f"commands {breakpoint_number}\nend"
        result = _run_gdb_command_with_echo(script, source="MCP", echo=True)

        return f"Commands cleared for breakpoint {breakpoint_number}.\n{result}"

    # ── Thread & Frame Navigation ──────────────────────────────────

    @app.tool()
    def gdb_get_threads() -> str:
        """List all threads with id, target-id, name, and current frame.
        Returns: JSON array of thread objects."""
        raw = _run_gdb_command_with_echo("info threads", source="MCP", echo=True)
        threads = []
        for line in raw.splitlines():
            m = re.match(r'(\*)?\s+(\d+)\s+(.+)', line)
            if m:
                threads.append({
                    "current": m.group(1) == '*',
                    "id": int(m.group(2)),
                    "details": m.group(3).strip()
                })
        return json.dumps(threads, indent=2) if threads else raw

    @app.tool()
    def gdb_select_thread(thread_id: int) -> str:
        """Switch to a specific thread by its GDB thread id.
        Args: thread_id: Thread number from info threads."""
        return _run_gdb_command_with_echo(f"thread {thread_id}", source="MCP", echo=True)

    @app.tool()
    def gdb_get_backtrace(full: bool = False, limit: int = 0) -> str:
        """Get the stack backtrace for the current thread.
        Args:
            full: If True, also print local variables in each frame.
            limit: Max frames (0 = unlimited)."""
        cmd = "bt full" if full else "bt"
        if limit > 0:
            cmd += f" {limit}"
        return _run_gdb_command_with_echo(cmd, source="MCP", echo=True)

    @app.tool()
    def gdb_select_frame(frame_number: int) -> str:
        """Select a stack frame by number (0 = innermost).
        Args: frame_number: Frame index from backtrace."""
        return _run_gdb_command_with_echo(f"frame {frame_number}", source="MCP", echo=True)

    @app.tool()
    def gdb_get_frame_info() -> str:
        """Get detailed info about the currently selected stack frame.
        Returns: JSON with frame, args, locals, and source location."""
        state = {}
        state["frame"] = _run_gdb_command_with_echo("info frame", source="SYSTEM", echo=False)
        state["args"] = _run_gdb_command_with_echo("info args", source="SYSTEM", echo=False)
        state["locals"] = _run_gdb_command_with_echo("info locals", source="SYSTEM", echo=False)
        try:
            state["source"] = _run_gdb_command_with_echo("list", source="SYSTEM", echo=False)
        except Exception:
            state["source"] = ""
        return json.dumps(state, indent=2)

    # ── Breakpoint Management ──────────────────────────────────────

    @app.tool()
    def gdb_set_breakpoint(location: str, condition: str = "", temporary: bool = False, hardware: bool = False) -> str:
        """Set a breakpoint at location (function, file:line, or *address).
        Args:
            location: e.g. 'main', 'foo.c:42', '*0x400520'
            condition: Optional conditional expression (e.g. 'x > 5')
            temporary: If True, breakpoint auto-deletes after first hit
            hardware: If True, use hardware breakpoint."""
        prefix = "thbreak" if temporary and hardware else "tbreak" if temporary else "hbreak" if hardware else "break"
        cmd = f"{prefix} {location}"
        result = _run_gdb_command_with_echo(cmd, source="MCP", echo=True)
        if condition:
            # Extract breakpoint number from output like "Breakpoint 3 at 0x..."
            m = re.search(r'[Bb]reakpoint\s+(\d+)', result)
            if m:
                bp_num = m.group(1)
                cond_result = _run_gdb_command_with_echo(
                    f"condition {bp_num} {condition}", source="MCP", echo=True)
                result += f"\n{cond_result}"
        return result

    @app.tool()
    def gdb_list_breakpoints() -> str:
        """List all breakpoints with full detail.
        Returns: Raw info breakpoints output."""
        return _run_gdb_command_with_echo("info breakpoints", source="MCP", echo=True)

    @app.tool()
    def gdb_delete_breakpoint(breakpoint_number: int) -> str:
        """Delete a breakpoint by its number.
        Args: breakpoint_number: Breakpoint number to delete."""
        return _run_gdb_command_with_echo(f"delete {breakpoint_number}", source="MCP", echo=True)

    @app.tool()
    def gdb_enable_breakpoint(breakpoint_number: int) -> str:
        """Enable a disabled breakpoint.
        Args: breakpoint_number: Breakpoint number to enable."""
        return _run_gdb_command_with_echo(f"enable {breakpoint_number}", source="MCP", echo=True)

    @app.tool()
    def gdb_disable_breakpoint(breakpoint_number: int) -> str:
