        Args: ignore_count: Number of times to skip before stopping (0 = stop next hit)."""
        cmd = f"continue {ignore_count}" if ignore_count > 0 else "continue"
        return _run_gdb_command_with_echo(cmd, source="MCP", echo=True)

    @app.tool()
    def gdb_step(count: int = 1) -> str:
